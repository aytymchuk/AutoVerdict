# AutoVerdikt — Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# docker-compose loads this file via `env_file: - .env` for all services.

# ─── Frontend ────────────────────────────────────────────────────────────────
# Vite build-time variable — baked into the JS bundle via Docker build arg.
# Get it from: https://dashboard.clerk.com → API Keys
VITE_CLERK_PUBLISHABLE_KEY=pk_test_

# Runtime
NODE_ENV=production

# ─── Backend ─────────────────────────────────────────────────────────────────
# ASP.NET Core runtime environment
ASPNETCORE_ENVIRONMENT=Development

# Clerk JWT authority — your Clerk Frontend API URL.
# Maps to appsettings key: Clerk:Authority
Clerk__Authority=https://<your-clerk-instance>.clerk.accounts.dev

# CORS allowed origin for the frontend. Use * to allow all in dev.
# Maps to appsettings key: Clerk:AuthorizedParty
Clerk__AuthorizedParty=http://localhost:3000

# ─── MongoDB ─────────────────────────────────────────────────────────────────
# Exposed on host port 27017
MONGO_URI=mongodb://localhost:27017

# ─── Azurite (Azure Storage Emulator) ────────────────────────────────────────
# Ports: Blob 10000 · Queue 10001 · Table 10002
AZURITE_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UKvwFN8KBq+Z6pG7l4==;BlobEndpoint=http://127.0.0.1:10000/devstoreaccount1;

# ─── Seq (Structured Logging) ────────────────────────────────────────────────
# UI available at http://localhost:5341
SEQ_URL=http://localhost:5341
# Required by the Seq Docker image — must be Y to accept the EULA
ACCEPT_EULA=Y
