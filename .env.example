# AutoVerdikt Environment Configuration
# Copy this file to .env and fill in the values for your environment.
# Never commit .env to version control.

# ─── Frontend (Vite build-time, passed as Docker build arg) ──────────────────
# Clerk publishable key from https://dashboard.clerk.com → API Keys
VITE_CLERK_PUBLISHABLE_KEY=pk_test_

# ─── Backend (ASP.NET Core — set via appsettings.Development.json or env vars) ─
# Clerk JWT authority (your Clerk Frontend API URL)
# Maps to: Clerk__Authority
Clerk__Authority=https://<your-clerk-instance>.clerk.accounts.dev

# Allowed CORS origin (frontend URL). Use * to allow all origins in dev.
# Maps to: Clerk__AuthorizedParty
Clerk__AuthorizedParty=http://localhost:3000

# ─── Infrastructure (docker-compose services) ────────────────────────────────
# MongoDB — exposed on host port 27017
MONGO_URI=mongodb://localhost:27017

# Azurite (Azure Storage emulator) — Blob:10000, Queue:10001, Table:10002
AZURITE_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UKvwFN8KBq+Z6pG7l4==;BlobEndpoint=http://127.0.0.1:10000/devstoreaccount1;

# Seq (structured logging UI) — UI at http://localhost:5341
SEQ_URL=http://localhost:5341

# ─── API server ───────────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development
# API is exposed on host port 5065
API_PORT=5065
